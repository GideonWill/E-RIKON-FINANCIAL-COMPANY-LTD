generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  SUPER_ADMIN
  BRANCH_ADMIN
  TELLER
  FIELD_OFFICER
  LOAN_OFFICER
  AUDITOR
}

enum CustomerStatus {
  PENDING
  VERIFIED
  ACTIVE
  DORMANT
  SUSPENDED
  CLOSED
}

enum AccountType {
  SAVINGS
  CURRENT
  EDUCATION_FUND
  RETIREMENT_FUND
  LOAN_ACCOUNT
}

enum AccountStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  INTEREST_CHARGE
  COMPANY_FEE_DEDUCTION
  PENALTY_FEE
}

enum PaymentMode {
  PHYSICAL_CASH
  MTN_MOBILE_MONEY
  BANK_TRANSFER
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum LoanStatus {
  PENDING_REVIEW
  UNDER_EVALUATION
  APPROVED
  DISBURSED
  ACTIVE
  IN_ARREARS
  FULLY_PAID
  REJECTED
}

enum EntryType {
  DEBIT
  CREDIT
}

model Branch {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  address     String
  city        String
  region      String
  phone       String
  cashLimit   Decimal  @default(100000.00) @db.Decimal(14, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  customers    Customer[]
  transactions Transaction[]
  accounts     Account[]

  @@map("branches")
}

model User {
  id           String   @id @default(uuid())
  employeeId   String   @unique
  firstName    String
  lastName     String
  email        String   @unique
  phone        String
  passwordHash String
  role         RoleName
  branchId     String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch       Branch        @relation(fields: [branchId], references: [id])
  createdCustomers Customer[] @relation("CreatedBy")
  recordedTransactions Transaction[] @relation("RecordedBy")
  approvedTransactions Transaction[] @relation("ApprovedBy")
  approvedLoans        LoanApplication[] @relation("LoanApprovedBy")
  auditLogs    AuditLog[]
  dailySummaries DailyCashSummary[]

  @@map("users")
}

model Customer {
  id               String         @id @default(uuid())
  customerNumber   String         @unique
  firstName        String
  lastName         String
  otherNames       String?
  dateOfBirth      DateTime
  gender           String
  phone            String         @unique
  email            String?
  address          String
  ghanaCardNumber  String         @unique
  passportPhotoUrl String?
  signatureUrl     String?
  ghanaCardFrontUrl String?
  ghanaCardBackUrl String?
  occupation       String
  employerName     String?
  monthlyIncome    Decimal?       @db.Decimal(12, 2)
  branchId         String
  createdById      String
  status           CustomerStatus @default(PENDING)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  branch           Branch         @relation(fields: [branchId], references: [id])
  createdBy        User           @relation("CreatedBy", fields: [createdById], references: [id])
  accounts         Account[]
  nextOfKin        NextOfKin?
  guarantors       Guarantor[]
  timeline         CustomerTimeline[]
  documents        CustomerDocument[]
  loanApplications LoanApplication[]
  dailyCollections DailyCollectionCycle[]

  @@map("customers")
}

model NextOfKin {
  id           String   @id @default(uuid())
  customerId   String   @unique
  fullName     String
  relationship String
  phone        String
  address      String
  occupation   String?
  createdAt    DateTime @default(now())

  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("next_of_kin")
}

model Guarantor {
  id              String   @id @default(uuid())
  customerId      String
  fullName        String
  relationship    String
  phone           String
  ghanaCardNumber String
  address         String
  occupation      String
  monthlyIncome   Decimal? @db.Decimal(12, 2)
  idCardPhotoUrl  String?
  createdAt       DateTime @default(now())

  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("guarantors")
}

model Account {
  id               String        @id @default(uuid())
  accountNumber    String        @unique
  customerId       String
  branchId         String
  type             AccountType
  currentBalance   Decimal       @default(0.00) @db.Decimal(14, 2)
  availableBalance Decimal       @default(0.00) @db.Decimal(14, 2)
  interestRate     Decimal       @default(0.00) @db.Decimal(5, 2)
  status           AccountStatus @default(ACTIVE)
  openingDate      DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  customer         Customer      @relation(fields: [customerId], references: [id])
  branch           Branch        @relation(fields: [branchId], references: [id])
  transactions     Transaction[]
  ledgerEntries    LedgerEntry[]
  loanApplications LoanApplication[]
  dailyCycles      DailyCollectionCycle[]

  @@map("accounts")
}

model DailyCollectionCycle {
  id                String   @id @default(uuid())
  customerId        String
  accountId         String
  cycleNumber       Int      @default(1)
  currentDayCount   Int      @default(0) // 1 to 31
  dailyTargetAmount Decimal  @db.Decimal(12, 2)
  totalDeposited    Decimal  @default(0.00) @db.Decimal(12, 2)
  feeDeducted       Boolean  @default(false) // True when 31st day / 1-day fee retained by company
  companyFeeAmount  Decimal  @default(0.00) @db.Decimal(12, 2)
  cycleStartDate    DateTime @default(now())
  cycleEndDate      DateTime?
  isCompleted       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer          Customer @relation(fields: [customerId], references: [id])
  account           Account  @relation(fields: [accountId], references: [id])

  @@map("daily_collection_cycles")
}

model LoanProduct {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String   // ER-Fast Loan, Business Growth Loan, etc.
  minAmount   Decimal  @db.Decimal(12, 2)
  maxAmount   Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())

  // Tenor Rates:
  // 1 Day to 4 Weeks: 10% (0.10)
  // 1 Month to 3 Months: 15% (0.15)
  // 3 Months to 6 Months: 25% (0.25)
  // 6 Months to 12 Months: 30% (0.30)
  
  applications LoanApplication[]

  @@map("loan_products")
}

model LoanApplication {
  id               String          @id @default(uuid())
  applicationNo   String          @unique
  customerId       String
  accountId        String
  productId        String
  amountRequested  Decimal         @db.Decimal(12, 2)
  amountApproved   Decimal?        @db.Decimal(12, 2)
  tenorCategory    String          // "1_WEEK_TO_4_WEEKS", "1_TO_3_MONTHS", "3_TO_6_MONTHS", "6_TO_12_MONTHS"
  tenorValueDays   Int             // Exact duration in days
  interestRate     Decimal         @db.Decimal(5, 2) // 10%, 15%, 25%, 30%
  totalInterest    Decimal         @default(0.00) @db.Decimal(12, 2)
  totalRepayable   Decimal         @default(0.00) @db.Decimal(12, 2)
  outstandingBal   Decimal         @default(0.00) @db.Decimal(12, 2)
  purpose          String
  status           LoanStatus      @default(PENDING_REVIEW)
  approvedById     String?
  disbursedAt      DateTime?
  dueDate          DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  customer         Customer        @relation(fields: [customerId], references: [id])
  account          Account         @relation(fields: [accountId], references: [id])
  product          LoanProduct     @relation(fields: [productId], references: [id])
  approvedBy       User?           @relation("LoanApprovedBy", fields: [approvedById], references: [id])
  schedules        LoanSchedule[]
  collaterals      LoanCollateral[]
  loanGuarantors   LoanGuarantor[]

  @@map("loan_applications")
}

model LoanSchedule {
  id               String    @id @default(uuid())
  loanId           String
  installmentNo    Int
  dueDate          DateTime
  principalDue     Decimal   @db.Decimal(12, 2)
  interestDue      Decimal   @db.Decimal(12, 2)
  totalDue         Decimal   @db.Decimal(12, 2)
  principalPaid    Decimal   @default(0.00) @db.Decimal(12, 2)
  interestPaid     Decimal   @default(0.00) @db.Decimal(12, 2)
  penaltyPaid      Decimal   @default(0.00) @db.Decimal(12, 2)
  isPaid           Boolean   @default(false)
  paidAt           DateTime?

  loan             LoanApplication @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_schedules")
}

model LoanCollateral {
  id               String   @id @default(uuid())
  loanId           String
  itemType         String
  description      String
  estimatedValue   Decimal  @db.Decimal(12, 2)
  documentUrl      String?
  createdAt        DateTime @default(now())

  loan             LoanApplication @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_collaterals")
}

model LoanGuarantor {
  id              String   @id @default(uuid())
  loanId          String
  fullName        String
  phone           String
  ghanaCardNumber String
  address         String
  relationship    String
  guaranteedAmount Decimal @db.Decimal(12, 2)
  createdAt       DateTime @default(now())

  loan            LoanApplication @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_guarantors")
}

model Transaction {
  id             String            @id @default(uuid())
  referenceNo    String            @unique
  receiptNo      String            @unique
  accountId      String
  branchId       String
  type           TransactionType
  paymentMode    PaymentMode
  amount         Decimal           @db.Decimal(14, 2)
  previousBal    Decimal           @db.Decimal(14, 2)
  newBal         Decimal           @db.Decimal(14, 2)
  status         TransactionStatus @default(COMPLETED)
  recordedById   String
  approvedById   String?
  remarks        String?
  externalRef    String?           // MoMo reference / Bank slip reference
  createdAt      DateTime          @default(now())

  account        Account           @relation(fields: [accountId], references: [id])
  branch         Branch            @relation(fields: [branchId], references: [id])
  recordedBy     User              @relation("RecordedBy", fields: [recordedById], references: [id])
  approvedBy     User?             @relation("ApprovedBy", fields: [approvedById], references: [id])
  ledgerEntries  LedgerEntry[]

  @@map("transactions")
}

model LedgerEntry {
  id            String      @id @default(uuid())
  transactionId String
  accountId     String
  accountName   String      // e.g. "Vault Cash", "Customer Savings Liability", "Interest Revenue"
  entryType     EntryType   // DEBIT or CREDIT
  amount        Decimal     @db.Decimal(14, 2)
  createdAt     DateTime    @default(now())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account       Account     @relation(fields: [accountId], references: [id])

  @@map("ledger_entries")
}

model CustomerDocument {
  id          String   @id @default(uuid())
  customerId  String
  documentType String  // GHANA_CARD, PASSPORT_PHOTO, SIGNATURE, LOAN_AGREEMENT, PROOF_OF_ADDRESS
  fileUrl     String
  fileName    String
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_documents")
}

model CustomerTimeline {
  id          String   @id @default(uuid())
  customerId  String
  title       String
  description String
  performedBy String
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_timelines")
}

model AuditLog {
  id            String   @id @default(uuid())
  userId        String?
  userEmail     String?
  userRole      String?
  branchName    String?
  action        String   // e.g. "CUSTOMER_REGISTERED", "DEPOSIT_RECORDED", "LOAN_APPROVED"
  resource      String   // e.g. "CUSTOMER", "TRANSACTION", "LOAN"
  previousValue String?  @db.Text
  newValue      String?  @db.Text
  ipAddress     String?
  browser       String?
  os            String?
  createdAt     DateTime @default(now())

  user          User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model DailyCashSummary {
  id            String   @id @default(uuid())
  branchId      String
  tellerId      String
  date          DateTime @default(dbgenerated("CURRENT_DATE"))
  openingCash   Decimal  @db.Decimal(14, 2)
  totalDeposits Decimal  @default(0.00) @db.Decimal(14, 2)
  totalWithdrawals Decimal @default(0.00) @db.Decimal(14, 2)
  closingCash   Decimal  @db.Decimal(14, 2)
  status        String   @default("BALANCED") // BALANCED, DISCREPANCY, PENDING_APPROVAL
  notes         String?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [tellerId], references: [id])

  @@map("daily_cash_summaries")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}
