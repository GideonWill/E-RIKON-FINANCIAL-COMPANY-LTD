# Database Connection String (PostgreSQL)
# Note: For Vercel Serverless, use a connection pooler URL (e.g. Supabase, Neon, or Prisma Accelerate)
DATABASE_URL="postgresql://user:password@host:5432/erikon_db?schema=public&pgbouncer=true"

# Server Port (used when running standalone server)
PORT=4000

# Authentication / Security
JWT_SECRET="your_production_jwt_secret_key_here"
